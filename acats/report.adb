PACKAGE BODY REPORT IS F:INTEGER:=0;TN:STRING(1..15);TNL:INTEGER:=0;PROCEDURE P(C:INTEGER);PRAGMA IMPORT(C,P,"__text_io_put_char");PROCEDURE NL;PRAGMA IMPORT(C,NL,"__text_io_new_line");PROCEDURE TEST(NAME:STRING;DESC:STRING)IS BEGIN F:=0;TNL:=NAME'LENGTH;IF TNL>15 THEN TNL:=15;END IF;TN(1..TNL):=NAME(NAME'FIRST..NAME'FIRST+TNL-1);P(84);P(69);P(83);P(84);P(32);FOR I IN NAME'RANGE LOOP P(CHARACTER'POS(NAME(I)));END LOOP;P(58);P(32);FOR I IN DESC'RANGE LOOP P(CHARACTER'POS(DESC(I)));END LOOP;NL;END;PROCEDURE FAILED(MSG:STRING)IS BEGIN P(70);P(65);P(73);P(76);P(69);P(68);P(58);P(32);FOR I IN MSG'RANGE LOOP P(CHARACTER'POS(MSG(I)));END LOOP;NL;F:=1;END;PROCEDURE RESULT IS BEGIN IF F/=0 THEN P(70);P(65);P(73);P(76);P(69);P(68);ELSE P(80);P(65);P(83);P(83);P(69);P(68);END IF;NL;END;PROCEDURE COMMENT(MSG:STRING)IS BEGIN P(67);P(79);P(77);P(77);P(69);P(78);P(84);P(58);P(32);FOR I IN MSG'RANGE LOOP P(CHARACTER'POS(MSG(I)));END LOOP;NL;END;FUNCTION IDENT_INT(X:INTEGER)RETURN INTEGER IS BEGIN RETURN X;END;FUNCTION IDENT_BOOL(X:BOOLEAN)RETURN BOOLEAN IS BEGIN RETURN X;END;FUNCTION IDENT_CHAR(X:CHARACTER)RETURN CHARACTER IS BEGIN RETURN X;END;FUNCTION IDENT_STR(X:STRING)RETURN STRING IS BEGIN RETURN X;END;FUNCTION EQUAL(X,Y:INTEGER)RETURN BOOLEAN IS BEGIN RETURN X=Y;END;FUNCTION LEGAL_FILE_NAME(X:FILE_NUM:=1;NAM:STRING:="")RETURN STRING IS R:STRING(1..24);L:INTEGER:=2;BEGIN R(1):='X';R(2):=CHARACTER'VAL(48+INTEGER(X));IF NAM'LENGTH>0 THEN FOR I IN NAM'RANGE LOOP IF L<20 THEN L:=L+1;R(L):=NAM(I);END IF;END LOOP;ELSE FOR I IN 1..TNL LOOP L:=L+1;R(L):=TN(I);END LOOP;END IF;R(L+1):='.';R(L+2):='T';R(L+3):='M';R(L+4):='P';RETURN R(1..L+4);END;PROCEDURE NOT_APPLICABLE(DESCR:STRING)IS BEGIN P(78);P(79);P(84);P(32);P(65);P(80);P(80);P(76);P(73);P(67);P(65);P(66);P(76);P(69);P(58);P(32);FOR I IN DESCR'RANGE LOOP P(CHARACTER'POS(DESCR(I)));END LOOP;NL;END;END REPORT;
